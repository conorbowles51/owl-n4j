# PostgreSQL (shared with backend so file routes can enforce case permissions)
DATABASE_URL=postgresql+asyncpg://owl_us:owl_pw@postgres:5432/owl_db

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Redis
REDIS_URL=redis://redis:6379

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5-mini
OPENAI_EXTRACTION_MODEL=gpt-5-mini
OPENAI_RESOLUTION_MODEL=gpt-5-mini
OPENAI_SUMMARY_MODEL=gpt-5-mini
OPENAI_DOCUMENT_SUMMARY_MODEL=gpt-5-mini
OPENAI_QUALITY_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=16
OPENAI_EMBEDDING_MAX_BATCH_CHARS=80000
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AUDIO_TRANSCRIPTION_SEGMENT_SECONDS=240
AUDIO_TRANSCRIPTION_MAX_SINGLE_SECONDS=240

# Storage
STORAGE_PATH=/data/files

# Authentication (must match the main backend)
AUTH_SECRET_KEY=supersecretchange
AUTH_ALGORITHM=HS256

# Google Maps Geocoding
GOOGLE_MAPS_API_KEY=your-key-here
