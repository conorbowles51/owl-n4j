# PostgreSQL
DATABASE_URL=postgresql+asyncpg://owl_us:owl_pw@postgres:5432/owl_db

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Redis
REDIS_URL=redis://redis:6379
SERVICE_API_KEY=replace-with-a-long-random-service-secret

# OpenAI
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Must match the Loupe backend value so workers can decrypt provider credentials.
AI_CREDENTIAL_ENCRYPTION_KEY=replace-with-a-long-random-encryption-secret
OPENAI_MODEL=gpt-5.6-terra
OPENAI_EXTRACTION_MODEL=gpt-5.6-terra
OPENAI_RESOLUTION_MODEL=gpt-5.6-terra
OPENAI_SUMMARY_MODEL=gpt-5.6-terra
OPENAI_DOCUMENT_SUMMARY_MODEL=gpt-5.6-sol
OPENAI_QUALITY_MODEL=gpt-5.6-terra
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=16
OPENAI_EMBEDDING_MAX_BATCH_CHARS=80000
EXTRACTION_MAX_CONCURRENCY=6
DOCUMENT_SUMMARY_MAX_CONCURRENCY=3
CLAIM_VERIFICATION_ENABLED=true
CLAIM_VERIFICATION_MAX_CLAIMS=250
CLAIM_VERIFICATION_BATCH_SIZE=20
CLAIM_VERIFICATION_MAX_CONCURRENCY=2
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AUDIO_TRANSCRIPTION_SEGMENT_SECONDS=240
AUDIO_TRANSCRIPTION_MAX_SINGLE_SECONDS=240

# Image and PDF OCR
IMAGE_PROVIDER=tesseract
TESSERACT_LANG=eng
PDF_OCR_DPI=300
PDF_OCR_MAX_PIXELS=25000000
PDF_OCR_PAGE_TIMEOUT_SECONDS=60
PDF_OCR_MAX_CONCURRENCY=2

# Storage
STORAGE_PATH=/data/files
MAX_UPLOAD_FILE_BYTES=1073741824
MAX_UPLOAD_BATCH_FILES=50
MAX_UPLOAD_BATCH_BYTES=5368709120
UPLOAD_READ_CHUNK_BYTES=1048576
BATCH_FILE_MAX_CONCURRENCY=4
MAX_EXTRACTED_CHARACTERS=50000000
MAX_PDF_PAGES=2000
MAX_IMAGE_PIXELS=25000000
MAX_IMAGE_FILE_BYTES=50000000
MAX_TEXT_INPUT_BYTES=100000000
MAX_OFFICE_UNCOMPRESSED_BYTES=500000000
MAX_OFFICE_ARCHIVE_ENTRIES=10000

# Google Maps Geocoding
GOOGLE_MAPS_API_KEY=your-key-here
