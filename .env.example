# Backend service
API_HOST=0.0.0.0
API_PORT=8002
CORS_ORIGINS=http://localhost:5174,http://localhost:3000
DATABASE_URL=postgresql+psycopg://owl_us:owl_pw@localhost:5434/owl_db

# Frontend V2 dev server
FRONTEND_PORT=5174
VITE_API_PROXY_TARGET=http://127.0.0.1:8002

# Neo4j
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword

# Chroma / Redis / Evidence Engine
CHROMADB_HOST=localhost
CHROMADB_PORT=8101
REDIS_URL=redis://localhost:6380
EVIDENCE_ENGINE_URL=http://localhost:8003
EVIDENCE_ENGINE_TIMEOUT=300
USE_EVIDENCE_ENGINE=true

# OpenAI / LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Optional local overrides
IMAGE_PROVIDER=tesseract
TESSERACT_LANG=eng
OPENAI_VISION_MODEL=gpt-4o
